% Description: Crée un diagramme d'utilisation
\newenvironment{quickusecasediagram}[3][1.0]{
    \def\quc@caption{#2} % Pour éviter des conflits avec d'autres variables
    \def\quc@label{#3} % Pour éviter des conflits avec d'autres variables
    \begin{figure}[H]
    \centering
    \begin{tikzpicture}[scale=#1, every node/.style={scale=#1}]
}{
    \end{tikzpicture}
    \caption{\quc@caption}
    \label{fig:\quc@label}
    \end{figure}
}

