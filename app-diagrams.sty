\begin{comment}
--------------------------------------
Définition des styles requis 
--------------------------------------
\end{comment}

\tikzset{
    % Exemple: \node[umlclass] (ID) at (0, 0)
    %          {className};
    % Description: Style du cadre
    umlclass/.style={
        rectangle, draw=black, thick,
        minimum width=3.8cm, minimum height=0.85cm,
        align=center, fill=gray!20,
        font=\bfseries,
        inner sep=0pt
    },
    % Exemple: \node[umlclassnode] (ID) at (0, 0)
    %          {className};
    % Description: Style d'une boite dans une classe
    umlclassnode/.style={
    inner sep=0pt
    },
    % Exemple: \draw[umlheritage]
    %     (ID1.north) -- ++(0, 0.5) -- ++(3.5, 0) --
    %     (ID2.west);
    % Description: Style de la relation d'héritage
    umlheritage/.style={
        -{Triangle[open,length=9pt,width=7pt]}, thick
    },
    % Exemple: \draw[umlassoc] (-4.1, 0.9) -- (ID.west);
    % Description: Style de la relation d'association
    umlassoc/.style={thick},
    % Exemple: \draw[umlcomp] (-4.1, 0.9) -- (ID.west);
    % Description: Style de la relation de composition
    umlcomp/.style={->, >=stealth, thick, dashed},
    % Exemple: \draw[umlextend] (node1.east) 
    %                 -- ++(x1, y1) 
    %                 -- node[right, font=\scriptsize]{<<extend>>} ++(x2, y2) 
     %                -- (node2.east);
    % Description: Style de la relation d'inclusion (en
    %              exemple utilisé dans ce document .sty)
    umlinclude/.style={-{Latex}, dashed, thick},
    % Exemple: \draw[umlextend] (label1.east) 
    %                 -- ++(x1, y1) 
    %                 -- node[right, font=\scriptsize]{<<extend>>} ++(x2, y2) 
    %                 -- (label2.east);
    % Description: Style de la relation d'extension (en
    %              exemple utilisé dans ce document .sty)
    umlextend/.style={-{Latex}, dashed, thick},
}
\begin{comment}
--------------------------------------
Définition de certaines commandes utiles
pour faire un diagramme UML
--------------------------------------
\end{comment}

% Exemple: \umlactor{nom}{x}{y}
% Description: Dessine un acteur UML à la position (x,y)
\newcommand{\umlactor}[3]{
    \draw[thick] (#2, #3+1.5) circle (0.35cm);
    \draw[thick] (#2, #3+1.15) -- (#2, #3+0.1);
    \draw[thick] (#2-0.45, #3+0.7) -- (#2, #3+0.9) -- (#2+0.45, #3+0.7);
    \draw[thick] (#2, #3+0.1) -- (#2-0.35, #3-0.7);
    \draw[thick] (#2, #3+0.1) -- (#2+0.35, #3-0.7);
    \node at (#2, #3-1.1) {\textbf{#1}};
}
 
% Exemple: \umlsystem{x1}{y1}{x2}{y2}{Nom}
% Description: Dessine le cadre du système avec son titre
\newcommand{\umlsystem}[5]{
    \draw[thick, rounded corners=6pt] (#1,#2) rectangle (#3,#4);
    \node[font=\bfseries\large] at ({(#1+#3)/2}, {#4-0.5}) {#5};
}
 
% Exemple: \umlusecase{id}{x}{y}{Texte}
% Description: Dessine un cas d'utilisation
\newcommand{\umlusecase}[4]{
    \node[draw, thick, ellipse, align=center,
          minimum width=4.2cm, minimum height=1.0cm] (#1) at (#2,#3) {#4};
}

% Exemple :
%   \begin{umlclassbox}[size]{className}
%            \umlattr{- attribute : type}
%            \umlattr{- attribute : type}
%            \umlattrbreak
%            \umlmethod{+ constructor(parameter : type)}
%            \umlmethod{+ method1()}
%            \umlmethod{+ method2()}
%    \end{umlclassbox}
% Description: Génère le tableau d'une classe UML
\newenvironment{umlclassbox}[2][5cm]{
    \begin{tabular}{|p{#1}|}
    \hline
    \multicolumn{1}{|c|}{\textbf{#2}} \\
    \hline
}{
    \hline
    \end{tabular}
}
 
% Attribut dans une classe
\newcommand{\umlattr}[1]{\texttt{#1} \\}
 
% Séparateur horizontal entre les sections attributs et méthodes
\newcommand{\umlattrbreak}{\hline}
 
% Méthode dans une classe
\let\umlmethod\umlattr
 
% Exemples: \umlrelation{type}{from}{to}{label}
%   type : heritage 
%          assoc 
%          comp
%          include
%          extend
%   label : optionnel, affiché au-dessus de la flèche
% Description: Raccourci pour les relations communes
\newcommand{\umlrelation}[5][above]{%
    % #1 = position du label (optionnel, défaut: above)
    % #2 = type : heritage, assoc, comp, include, extend
    % #3 = from
    % #4 = to
    % #5 = label : optionnel, affiché au-dessus de la flèche
    \ifthenelse{\equal{#2}{heritage}}{
        \draw[umlheritage] (#3) -- node[#1, font=\scriptsize]{#5} (#4);
    }{}
    \ifthenelse{\equal{#2}{assoc}}{
        \draw[umlassoc] (#3) -- node[#1, font=\scriptsize]{#5} (#4);
    }{}
    \ifthenelse{\equal{#2}{comp}}{
        \draw[umlcomp] (#3) -- node[#1, font=\scriptsize]{#5} (#4);
    }{} 
    % \umlrelation[right]{include}{uc6}{uc5}{}
    \ifthenelse{\equal{#2}{include}}{
        \draw[umlinclude] (#3) -- node[#1, font=\scriptsize]{<<include>>} (#4);
    }{}
    \ifthenelse{\equal{#2}{extend}}{
        \draw[umlextend] (#3) -- node[#1, font=\scriptsize]{<<extend>>} (#4);
    }{}
}

\begin{comment}
--------------------------------------
Définition de certaines commandes pour
créer directement certains diagrammes UML
--------------------------------------
\end{comment}

% Exemple:
%   \begin{quickclassdiagram}{Diagramme de classes}{fig:classes}
%       \node[umlclass] (label1) at (x, y) {\textbf{Name}};
%       \node[umlclassnode] (label2) at (x, y) {%
%           \begin{umlclassbox}[size]{Name}
%               \umlattr{- attribute : Type}
%               \umlattrbreak
%               \umlmethod{+ method()}
%           \end{umlclassbox}
%       };
%       \draw[umlheritage] (label2.north) -- (label1.south);
%   \end{quickclassdiagram}
% Description: Crée un diagramme de classe
\newenvironment{quickclassdiagram}[3][1.0]{
    \def\qcd@caption{#2} % Pour éviter des conflits avec d'autres variables
    \def\qcd@label{#3} % Pour éviter des conflits avec d'autres variables
    \begin{figure}[H]
    \centering
    \begin{tikzpicture}[scale=#1, every node/.style={scale=#1}]
}{
    \end{tikzpicture}
    \caption{\qcd@caption}
    \label{fig:\qcd@label}
    \end{figure}
}

% Exemple:
%   \begin{quickusecasediagram}[size]{Name}{fig:label}
%       \umlsystem{x1}{y1}{x2}{y2}{Name}
%       \umlactor{Utilisateur}{x}{y}
